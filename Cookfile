# Cookfile for cook-modules — the source-of-truth monorepo for blessed
# Cook modules published to rocks.usecook.com.
#
# Publishing a new revision (canonical flow, run from this directory):
#   1. Edit/add cook_<name>/cook_<name>-<X.Y.Z>-<R>.rockspec on a clean main
#   2. git commit
#   3. MODULE=cook_<name> VERSION=<X.Y.Z>-<R> cook publish
#
# `cook publish` runs the whole pipeline locally — tag HEAD, push to Gitea
# (origin) and GitHub (github) so luarocks pack can fetch the source.url
# tag, pack the rock, stage it in ~/dev/cook-rocks, commit there, and
# invoke that repo's own `cook publish` which pushes to Gitea and force-
# pushes the GitHub orphan snapshot Cloudflare Pages serves.
#
# `pack` and `publish-to-index` are piecewise helpers for debugging; both
# require MODULE and VERSION.

chore pack
    : "${MODULE:?set MODULE=<name>}" "${VERSION:?set VERSION=<x.y.z-rockrev>}"
    cd "${MODULE}" && luarocks pack "${MODULE}-${VERSION}.rockspec"

chore publish-to-index
    : "${MODULE:?set MODULE=<name>}" "${VERSION:?set VERSION=<x.y.z-rockrev>}"
    cp "${MODULE}/${MODULE}-${VERSION}.rockspec" "${HOME}/dev/cook-rocks/"
    cp "${MODULE}/${MODULE}-${VERSION}.src.rock" "${HOME}/dev/cook-rocks/"
    cd "${HOME}/dev/cook-rocks" && luarocks-admin make-manifest .
    echo "Staged in ${HOME}/dev/cook-rocks — review, then run 'cook publish' from there."

chore publish
    : "${MODULE:?set MODULE=<name>}" "${VERSION:?set VERSION=<x.y.z-rockrev>}"
    ls "${MODULE}/${MODULE}-${VERSION}.rockspec" >/dev/null
    git tag -a "${MODULE}-${VERSION}" -m "${MODULE}-${VERSION}"
    git push github main "${MODULE}-${VERSION}"
    git push origin main "${MODULE}-${VERSION}"
    cd "${MODULE}" && luarocks pack "${MODULE}-${VERSION}.rockspec"
    cp "${MODULE}/${MODULE}-${VERSION}.rockspec" "${HOME}/dev/cook-rocks/"
    cp "${MODULE}/${MODULE}-${VERSION}.src.rock" "${HOME}/dev/cook-rocks/"
    cd "${HOME}/dev/cook-rocks" && luarocks-admin make-manifest .
    cd "${HOME}/dev/cook-rocks" && git add manifest manifest-5.* index.html "${MODULE}-${VERSION}.rockspec" "${MODULE}-${VERSION}.src.rock"
    cd "${HOME}/dev/cook-rocks" && git commit -m "publish: ${MODULE}-${VERSION}"
    cd "${HOME}/dev/cook-rocks" && cook publish

chore spec
    : "${MODULE:=cook_cc}"
    cd "${MODULE}" && busted .
