# Cookfile for cook-modules — the source-of-truth monorepo for blessed
# Cook modules published to rocks.usecook.com.
#
# Quick reference (v1, manual):
#   cook pack <module>             - run luarocks pack against the live tag for one module
#   cook publish-to-index <module> - copy artifacts into ~/dev/cook-rocks/ + regen manifest
#   cook tag-module <module>=<ver> - shortcut to git tag <module>-<ver>
#
# Phase 4 will wire these into CI on tag push.

# Pack one module's rockspec into a .src.rock. Requires the module's tag
# to be pushed to GitHub (luarocks fetches source via git+https).
chore pack
    > local mod = cook.env.MODULE or error("set MODULE=<name>")
    > local cd = "cd " .. mod
    > local cmd = cd .. " && luarocks pack " .. mod .. "-*.rockspec"
    > cook.exec(cmd)

# Copy a module's rockspec + .src.rock into ~/dev/cook-rocks/, regenerate
# the manifest, and stage them for commit. Does not push.
chore publish-to-index
    > local mod = cook.env.MODULE or error("set MODULE=<name>")
    > local index = os.getenv("HOME") .. "/dev/cook-rocks"
    > cook.exec("cp " .. mod .. "/" .. mod .. "-*.rockspec " .. index .. "/")
    > cook.exec("cp " .. mod .. "/" .. mod .. "-*.src.rock " .. index .. "/")
    > cook.exec("cd " .. index .. " && luarocks-admin make-manifest .")
    > print("Staged in " .. index .. " — review with `git -C " .. index .. " status` then `cook publish` from there.")
